# Traefik dynamic config — default
# Managed by: automation/ansible/roles/traefik

http:
  middlewares:
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true

    strip-traefik-prefix:
      stripPrefix:
        prefixes:
          - "/traefik"

    mgmt-ipallowlist:
      ipAllowList:
        sourceRange:
{% for cidr in traefik_dashboard_allowed_cidrs %}
          - "{{ cidr }}"
{% endfor %}

  routers:
    traefik-dashboard:
      rule: "Host(`{{ traefik_mgmt_hostname }}`) && (PathPrefix(`/traefik/api`) || PathPrefix(`/traefik/dashboard`))"
      entryPoints:
        - websecure
      service: api@internal
      middlewares:
        - mgmt-ipallowlist
        - strip-traefik-prefix
      tls:
        certResolver: letsencrypt
