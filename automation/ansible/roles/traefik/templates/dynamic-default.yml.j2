# Traefik dynamic config — default
# Managed by: automation/ansible/roles/traefik
{% set bq = '`' %}
http:
  middlewares:
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true

    strip-traefik-prefix:
      stripPrefix:
        prefixes:
          - "/traefik"

    mgmt-ipallowlist:
      ipAllowList:
        sourceRange:
{% for cidr in traefik_dashboard_allowed_cidrs %}
          - "{{ cidr }}"
{% endfor %}

  routers:
    traefik-dashboard:
      rule: "Host({{ bq }}{{ traefik_mgmt_hostname }}{{ bq }}) && (PathPrefix({{ bq }}/traefik/api{{ bq }}) || PathPrefix({{ bq }}/traefik/dashboard{{ bq }}))"
      entryPoints:
        - websecure
      service: api@internal
      middlewares:
        - mgmt-ipallowlist
        - strip-traefik-prefix
      tls:
        certResolver: letsencrypt
