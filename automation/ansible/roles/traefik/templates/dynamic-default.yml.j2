# Traefik dynamic config — default
# Managed by: automation/ansible/roles/traefik
{% set bq = '`' %}
http:
  middlewares:
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true

    mgmt-ipallowlist:
      ipAllowList:
        sourceRange:
{% for cidr in traefik_dashboard_allowed_cidrs %}
          - "{{ cidr }}"
{% endfor %}

  routers:
    traefik-dashboard:
      # Dedicated subdomain — avoids stripPrefix+SPA incompatibility.
      # Dashboard available at: https://{{ traefik_dashboard_hostname }}/dashboard/
      rule: "Host({{ bq }}{{ traefik_dashboard_hostname }}{{ bq }})"
      entryPoints:
        - websecure
      service: api@internal
      middlewares:
        - mgmt-ipallowlist
      tls:
        certResolver: letsencrypt
