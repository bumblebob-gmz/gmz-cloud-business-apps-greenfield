# Traefik v3 static configuration — rendered by Ansible
# Managed by: automation/ansible/roles/traefik

global:
  checkNewVersion: false
  sendAnonymousUsage: false

log:
  level: INFO

accessLog: {}

api:
  dashboard: true
  insecure: false

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true

  websecure:
    address: ":443"
    http:
      tls:
        certResolver: letsencrypt

certificatesResolvers:
  letsencrypt:
    acme:
      email: "{{ acme_email }}"
      storage: {{ traefik_acme_dir }}/acme.json
      dnsChallenge:
        provider: ionos
        resolvers:
          - "ns1.ionos.com:53"
          - "ns1095.ui-dns.biz:53"

providers:
  file:
    directory: {{ traefik_dynamic_dir }}
    watch: true
  docker:
    # Read container labels via socket proxy (not directly from Docker socket).
    # Socket proxy runs on the internal socket-proxy network, port 2375.
    endpoint: "tcp://socket-proxy:2375"
    exposedByDefault: false   # only containers with traefik.enable=true are routed
    network: traefik          # default network for backend containers
