# .env — auto-generated by authentik-bootstrap Ansible role
# Tenant:   {{ tenant_slug | default('unknown') }}
# Generated: {{ ansible_date_time.iso8601 }}
# Permissions: 0600 (root only). Do not commit.

# Authentik image version
AUTHENTIK_IMAGE_TAG={{ authentik_image_tag }}

# Database
AUTHENTIK_DB_NAME={{ authentik_db_name }}
AUTHENTIK_DB_USER={{ authentik_db_user }}
AUTHENTIK_DB_PASSWORD={{ _authentik_db_password }}

# Application secret key (used for signing sessions/tokens — rotate with care)
AUTHENTIK_SECRET_KEY={{ _authentik_secret_key }}

# Cookie domain — must match the base domain of the Traefik host
BASE_DOMAIN={{ base_domain }}

# Authentik host (must match the Traefik router rule)
AUTHENTIK_HOST=authentik.{{ tenant_slug }}.{{ base_domain }}

# Bootstrap credentials (only used on first startup; ignored on subsequent runs)
AUTHENTIK_BOOTSTRAP_EMAIL={{ authentik_bootstrap_email | default('admin@' + base_domain) }}
AUTHENTIK_BOOTSTRAP_PASSWORD={{ _authentik_bootstrap_password }}
