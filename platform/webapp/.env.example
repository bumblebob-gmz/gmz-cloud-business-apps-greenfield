# Environment variables for the webapp.
# Copy this file to .env (never commit .env) and fill in real values.
#
# See: https://pris.ly/prisma-config-env-vars

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local dev (prisma local): prisma+postgres://localhost:51213/?api_key=<local-dev-key>
# Remote Prisma Postgres:   prisma+postgres://accelerate.prisma-data.net/?api_key=<your-api-key>
# Plain Postgres:           postgres://user:password@localhost:5432/dbname
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=<your-local-or-remote-api-key>"

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Supported modes: "trusted-bearer" | "jwt" | "dev-header" (dev only)
# Default and recommended production mode: "trusted-bearer"
WEBAPP_AUTH_MODE="trusted-bearer"

# --- trusted-bearer mode ---
# JSON array of token entries. Each entry must have token, userId, and role.
# Roles: "readonly" | "technician" | "admin"
# Optional: tokenId (string), expiresAt (ISO 8601 datetime)
# Example:
WEBAPP_TRUSTED_TOKENS_JSON='[{"token":"change-me-use-a-long-random-secret","userId":"platform-admin","role":"admin","tokenId":"tok-001","expiresAt":"2027-01-01T00:00:00Z"}]'

# Number of days before token expiry to show warnings (default: 14)
# WEBAPP_TRUSTED_TOKEN_EXPIRY_WARNING_DAYS=14

# --- jwt mode ---
# Only required when WEBAPP_AUTH_MODE=jwt
# WEBAPP_OIDC_ISSUER="https://your-idp.example.com"
# WEBAPP_OIDC_AUDIENCE="your-api-audience"

# --- dev-header mode ---
# Only available when NODE_ENV=development AND WEBAPP_ENABLE_DEV_AUTH=true
# NEVER use in production!
# WEBAPP_ENABLE_DEV_AUTH=true

# ---------------------------------------------------------------------------
# Vault (optional, for token rotation)
# ---------------------------------------------------------------------------
VAULT_ADDR="http://127.0.0.1:8200"
VAULT_TOKEN="<your-vault-token>"

# ---------------------------------------------------------------------------
# Notification / Alerting (optional)
# ---------------------------------------------------------------------------
ALERTMANAGER_URL="http://localhost:9093"
