# Environment variables for the webapp.
# Copy this file to .env (never commit .env) and fill in real values.
#
# See: https://pris.ly/prisma-config-env-vars

# Prisma / Database
# Local dev (prisma local): prisma+postgres://localhost:51213/?api_key=<local-dev-key>
# Remote Prisma Postgres:   prisma+postgres://accelerate.prisma-data.net/?api_key=<your-api-key>
# Plain Postgres:           postgres://user:password@localhost:5432/dbname
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=<your-local-or-remote-api-key>"

# Auth
# Mode: "jwt" | "oidc" | "none"
WEBAPP_AUTH_MODE="none"

# JWT secret (only required when WEBAPP_AUTH_MODE=jwt)
JWT_SECRET="<replace-with-a-long-random-secret>"

# OIDC (only required when WEBAPP_AUTH_MODE=oidc)
OIDC_ISSUER_URL="https://your-idp.example.com"
OIDC_CLIENT_ID="<your-client-id>"
OIDC_CLIENT_SECRET="<your-client-secret>"

# Vault (optional, for token rotation)
VAULT_ADDR="http://127.0.0.1:8200"
VAULT_TOKEN="<your-vault-token>"

# Notification / Alerting (optional)
ALERTMANAGER_URL="http://localhost:9093"
