{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Huly tenant variables",
  "type": "object",
  "additionalProperties": false,
  "required": ["HULY_HOST", "HULY_VERSION", "HULY_SECRET", "HULY_MINIO_ROOT_PASSWORD", "HULY_MONGO_USER", "HULY_MONGO_PASSWORD", "HULY_ELASTIC_PASSWORD"],
  "properties": {
    "HULY_HOST": {
      "type": "string",
      "description": "Public hostname for Huly"
    },
    "HULY_VERSION": {
      "type": "string",
      "default": "v0.6.295",
      "description": "Huly (hcengineering) Docker image tag"
    },
    "HULY_SECRET": {
      "type": "string",
      "minLength": 32,
      "description": "Server secret for JWT signing and inter-service auth"
    },
    "HULY_MONGO_USER": {
      "type": "string",
      "description": "MongoDB root username (used for MONGO_INITDB_ROOT_USERNAME)"
    },
    "HULY_MONGO_PASSWORD": {
      "type": "string",
      "minLength": 16,
      "description": "MongoDB root password"
    },
    "HULY_ELASTIC_PASSWORD": {
      "type": "string",
      "minLength": 16,
      "description": "Elasticsearch built-in elastic user password (xpack.security)"
    },
    "HULY_DB_URL": {
      "type": "string",
      "description": "MongoDB connection URL (include credentials: mongodb://user:pass@huly-mongo:27017)"
    },
    "HULY_MINIO_ROOT_USER": {
      "type": "string",
      "default": "minioadmin",
      "description": "MinIO root user"
    },
    "HULY_MINIO_ROOT_PASSWORD": {
      "type": "string",
      "minLength": 20,
      "description": "MinIO root password"
    },
    "HULY_ELASTIC_URL": {
      "type": "string",
      "default": "http://huly-elastic:9200",
      "description": "Elasticsearch URL"
    }
  }
}
